# Excluded from WordPress.org SVN deploy (10up/action-wordpress-plugin-deploy).
# Same spirit as .gitattributes export-ignore — do NOT list resources/js; source ships with the plugin.

# VCS / CI
.git
.github
.gitignore
.gitattributes
.distignore

# WordPress.org repo assets (banner, screenshots) — action uploads these separately
.wordpress-org

