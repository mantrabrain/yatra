package.json
package-lock.json
yarn.lock
pnpm-lock.yaml
npm-debug.log*
composer.json
composer.lock

# Tooling & tests
phpcs.xml
phpcs.xml.dist
phpunit.xml
phpunit.xml.dist
.phpunit.result.cache
tests
scripts
docs

