vite.config.ts
tsconfig.json
tsconfig.node.json
tailwind.config.js
postcss.config.js
babel.config.cjs
vite
eslint.config.js
.prettierrc
.prettierrc.json
prettier.config.js

# Local / release helpers
build.sh
copy.sh
build
*.map
assets/.vite

# GitHub / internal only
README.md
UNUSED_SETTINGS_ANALYSIS.md
