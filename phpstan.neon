includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    paths:
        - app/
        - includes/
        - templates/
        - yatra.php
    
    excludePaths:
        - vendor/
        - node_modules/
        - */tests/*
        - */test/*
        - app/Providers/RouteServiceProvider.php
    
    # WordPress-specific configuration
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
    
    ignoreErrors:
        # Third-party library calls (DOMPDF, Action Scheduler)
        - '#Call to an undefined method Dompdf.*#'
        - '#Call to an undefined method ActionScheduler.*#'
        # Ignore missing array/generic typehints (common in WordPress)
        - identifier: missingType.iterableValue
        - identifier: missingType.generics
