includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    paths:
        - app/
        - includes/
        - templates/
        - yatra.php
    
    excludePaths:
        - vendor/
        - node_modules/
        - */tests/*
        - */test/*
        - app/Providers/RouteServiceProvider.php
        - templates/setup-wizard/*
        - templates/pdf/*
        - templates/examples/*
    
    # Performance optimizations
    reportUnmatchedIgnoredErrors: false
    tmpDir: build/phpstan
    
    # WordPress-specific configuration
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
    
    ignoreErrors:
        # Third-party library calls (DOMPDF, Action Scheduler)
        - '#Call to an undefined method Dompdf.*#'
        - '#Call to an undefined method ActionScheduler.*#'
        # WordPress dynamic properties (unavoidable in WP context)
        - '#Access to an undefined property object::\$.*#'
        - '#Variable \$this might not be defined#'
        # WordPress constants defined at runtime
        - '#Constant YATRA_PLUGIN_PATH not found#'
        - '#Constant YATRA_PLUGIN_URI not found#'
