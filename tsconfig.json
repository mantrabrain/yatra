{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./resources/js/*"],
      "@yatra/icons": ["./includes/icons.json"],
      "@yatra/fa-icon-names": ["./includes/fa-free-icon-names.json"]
    }
  },
  "include": ["resources/js", "includes/icons.json", "includes/fa-free-icon-names.json"],
  "references": [{ "path": "./tsconfig.node.json" }]
}

