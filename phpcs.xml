<?xml version="1.0"?>
<ruleset name="Yatra WordPress Plugin">
    <description>Yatra WordPress Plugin Coding Standards</description>
    
    <!-- WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- Exclude file naming rules (modern PSR-4 autoloading) -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        
        <!-- Exclude variable naming rules (allow camelCase for modern PHP) -->
        <exclude name="WordPress.NamingConventions.ValidVariableName.NotSnakeCaseMemberVar"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.PropertyNotSnakeCase"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
        
        <!-- Allow short array syntax [] alongside array() -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        
        <!-- Exclude Yoda conditions (modern PHP doesn't require them) -->
        <exclude name="WordPress.PHP.YodaConditions"/>
        
        <!-- Allow multiple assignments per line (common in modern PHP) -->
        <exclude name="Squiz.PHP.DisallowMultipleAssignments"/>
    </rule>
    
    <!-- Additional rules for modern PHP -->
    <!-- Deprecated functions are checked separately in CI workflow to avoid false positives -->
    <rule ref="Generic.PHP.Syntax"/>
    
    <!-- Directories to check -->
    <file>app</file>
    <file>includes</file>
    <file>templates</file>
    <file>yatra.php</file>
    
    <!-- Directories to exclude -->
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/test/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>
    
    <!-- File extensions -->
    <arg name="extensions" value="php"/>
    
    <!-- Show progress and colors -->
    <arg value="p"/>
    <arg name="colors"/>
</ruleset>
