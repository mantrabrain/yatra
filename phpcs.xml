<?xml version="1.0"?>
<ruleset name="Yatra WordPress Plugin">
    <description>Yatra WordPress Plugin - PHP 7.4 Compatibility Focus</description>
    
    <!-- Only check for syntax errors that would break PHP 7.4 compatibility -->
    <rule ref="Generic.PHP.Syntax"/>
    <rule ref="Generic.PHP.DisallowShortOpenTag"/>
    <rule ref="Generic.Files.ByteOrderMark"/>
    
    <!-- Directories to check -->
    <file>app</file>
    <file>includes</file>
    <file>templates</file>
    <file>yatra.php</file>
    
    <!-- Directories to exclude -->
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/test/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>
    
    <!-- File extensions -->
    <arg name="extensions" value="php"/>
    
    <!-- Show progress and colors -->
    <arg value="p"/>
    <arg name="colors"/>
</ruleset>
