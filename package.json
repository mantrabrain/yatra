{
  "name": "yatra-plugin",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf assets/admin/dist assets/dist",
    "build": "vite build && node scripts/generate-block-assets.js && npm run makepot",
    "dev": "npm run makepot && vite build --watch",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"resources/js/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --check \"resources/js/**/*.{ts,tsx,js,jsx}\"",
    "makepot": "babel assets/dist assets/admin/dist --out-file /dev/null && WP_MEMORY_LIMIT=1G php -d memory_limit=1G $(which wp) --allow-root i18n make-pot . i18n/languages/yatra.pot --include=\"app,includes,templates\" --domain=yatra --location --headers='{\"Language-Team\":\"Yatra Development Team <mantrabrain@gmail.com>\",\"Last-Translator\":\"Yatra Dev <mantrabrain@gmail.com>\",\"Language\":\"en_US\",\"Plural-Forms\":\"nplurals=2; plural=(n != 1);\"}' && WP_MEMORY_LIMIT=1G php -d memory_limit=1G $(which wp) --allow-root i18n make-pot . i18n/languages/yatra.pot --merge=i18n/languages/yatra-js.pot && rm -f i18n/languages/yatra-js.pot",
    "i18n": "npm run makepot"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.12.0",
    "@wordpress/i18n": "^4.58.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.294.0",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^18.2.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/wordpress__block-editor": "^15.0.5",
    "@types/wordpress__blocks": "^15.10.2",
    "@types/wordpress__components": "^23.0.12",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@wordpress/babel-plugin-makepot": "^6.37.0",
    "@wordpress/block-editor": "^15.14.0",
    "@wordpress/blocks": "^15.14.0",
    "@wordpress/components": "^32.3.0",
    "@wordpress/element": "^6.41.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.6",
    "terser": "^5.44.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
